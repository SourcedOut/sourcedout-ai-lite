{
  "manifest_version": 3,
  "name": "SourcedOut Lite",
  "version": "2.0.0",
  "description": "API-powered outreach for recruiters and talent sourcers.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "SourcedOut Lite"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "auth.html",
        "auth-callback.js",
        "icons/*"
      ],
      "matches": [
        "https://*.supabase.co/*"
      ]
    }
  ]
}
